#!/usr/bin/env bash
# ===========================================================================
# recon.sh — subfinder -> dnsx -> httpx -> nuclei, tidy per-target output
#
# Usage:
#   ./recon.sh <domain> [options]
#   ./recon.sh acme.com
#   ./recon.sh acme.com --passive          # stop after httpx, no active scan
#   ./recon.sh acme.com --scope scope.txt  # verify domain is in an allowlist
#   ./recon.sh acme.com --yes              # skip the scope confirmation prompt
#   ./recon.sh acme.com --severity high,critical
#
# Output:
#   output/<domain>/
#     ├── subdomains.txt     all discovered names
#     ├── resolved.txt       names that actually resolve (live DNS)
#     ├── live-http.txt      hosts running a web server (+ status/title/tech)
#     ├── live-urls.txt      just the URLs (clean list to feed Burp/other tools)
#     ├── nuclei-findings.txt vuln/misconfig hits (skipped with --passive)
#     └── recon.log          run log
#
# SCOPE DISCIPLINE: nuclei performs ACTIVE scanning. Only run this against
# domains explicitly in a program's scope, and check the program's policy on
# automated scanning first — some prohibit or rate-limit it. The script makes
# you confirm scope before the active stage unless you pass --yes.
# ===========================================================================
set -u

# ---- defaults --------------------------------------------------------------
DOMAIN=""
PASSIVE=0
ASSUME_YES=0
SCOPE_FILE=""
SEVERITY="low,medium,high,critical"   # nuclei severities to report
RATE=150                              # nuclei requests/sec (be a good citizen)
HTTPX_THREADS=50

# ---- args ------------------------------------------------------------------
while [ $# -gt 0 ]; do
  case "$1" in
    --passive)  PASSIVE=1; shift ;;
    --yes|-y)   ASSUME_YES=1; shift ;;
    --scope)    SCOPE_FILE="${2:-}"; shift 2 ;;
    --severity) SEVERITY="${2:-}"; shift 2 ;;
    --rate)     RATE="${2:-}"; shift 2 ;;
    -h|--help)  grep '^#' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    -*)         echo "unknown option: $1" >&2; exit 1 ;;
    *)          DOMAIN="$1"; shift ;;
  esac
done

[ -n "$DOMAIN" ] || { echo "usage: ./recon.sh <domain> [--passive] [--scope file] [--yes]"; exit 1; }

# ---- preflight: required tools --------------------------------------------
need() { command -v "$1" >/dev/null 2>&1 || { echo "missing tool: $1 (run bb-setup.sh)"; exit 1; }; }
need subfinder; need dnsx; need httpx
[ "$PASSIVE" -eq 1 ] || need nuclei

# ---- scope check -----------------------------------------------------------
if [ -n "$SCOPE_FILE" ]; then
  [ -f "$SCOPE_FILE" ] || { echo "scope file not found: $SCOPE_FILE"; exit 1; }
  if ! grep -qxF "$DOMAIN" "$SCOPE_FILE"; then
    echo "REFUSING: '$DOMAIN' is not listed in $SCOPE_FILE"; exit 2
  fi
  echo "[scope] $DOMAIN confirmed present in $SCOPE_FILE"
fi

# ---- output dirs -----------------------------------------------------------
OUT="output/$DOMAIN"
mkdir -p "$OUT"
LOG="$OUT/recon.log"
ts() { date -u +'%H:%M:%S'; }
say() { printf '\033[1;36m[%s] %s\033[0m\n' "$(ts)" "$*" | tee -a "$LOG"; }

say "target: $DOMAIN   output: $OUT   passive: $PASSIVE"

# ---- 1. subfinder : discover subdomains -----------------------------------
say "1/4 subfinder — discovering subdomains…"
subfinder -d "$DOMAIN" -all -silent 2>>"$LOG" | sort -u > "$OUT/subdomains.txt"
say "    found $(wc -l < "$OUT/subdomains.txt") subdomains"

# ---- 2. dnsx : keep only names that resolve -------------------------------
say "2/4 dnsx — resolving (dropping dead names)…"
dnsx -l "$OUT/subdomains.txt" -silent 2>>"$LOG" | sort -u > "$OUT/resolved.txt"
say "    $(wc -l < "$OUT/resolved.txt") resolve to a live host"

# ---- 3. httpx : keep only live web servers + metadata ---------------------
say "3/4 httpx — probing for live web servers…"
httpx -l "$OUT/resolved.txt" -silent \
      -threads "$HTTPX_THREADS" \
      -status-code -title -tech-detect -follow-redirects \
      -o "$OUT/live-http.txt" 2>>"$LOG"
# clean URL-only list for feeding into Burp / other tools
httpx -l "$OUT/resolved.txt" -silent -threads "$HTTPX_THREADS" 2>>"$LOG" \
      | sort -u > "$OUT/live-urls.txt"
say "    $(wc -l < "$OUT/live-urls.txt") live web hosts"

# ---- stop here if passive --------------------------------------------------
if [ "$PASSIVE" -eq 1 ]; then
  say "passive mode — stopping before nuclei."
  say "review: $OUT/live-http.txt"
  exit 0
fi

# ---- scope confirmation gate (before any active scanning) -----------------
if [ "$ASSUME_YES" -ne 1 ]; then
  echo
  echo "About to run nuclei (ACTIVE scanning) against $(wc -l < "$OUT/live-urls.txt") hosts under $DOMAIN."
  echo "Confirm this domain is IN SCOPE and the program permits automated scanning."
  printf "Type the domain to proceed: "
  read -r CONFIRM
  [ "$CONFIRM" = "$DOMAIN" ] || { echo "Aborted — no match."; exit 3; }
fi

# ---- 4. nuclei : scan live hosts for vulns/misconfigs ---------------------
say "4/4 nuclei — scanning (severity: $SEVERITY, rate: $RATE/s)…"
nuclei -l "$OUT/live-urls.txt" \
       -severity "$SEVERITY" \
       -rate-limit "$RATE" \
       -stats \
       -o "$OUT/nuclei-findings.txt" 2>>"$LOG"

FINDINGS=0
[ -f "$OUT/nuclei-findings.txt" ] && FINDINGS=$(wc -l < "$OUT/nuclei-findings.txt")
say "DONE — $FINDINGS nuclei findings → $OUT/nuclei-findings.txt"

# ---- summary ---------------------------------------------------------------
echo
echo "================ $DOMAIN ================"
printf "  subdomains found : %s\n" "$(wc -l < "$OUT/subdomains.txt")"
printf "  resolved         : %s\n" "$(wc -l < "$OUT/resolved.txt")"
printf "  live web hosts   : %s\n" "$(wc -l < "$OUT/live-urls.txt")"
printf "  nuclei findings  : %s\n" "$FINDINGS"
echo "  files in         : $OUT/"
echo "========================================"
